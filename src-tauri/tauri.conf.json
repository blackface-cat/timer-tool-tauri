{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "计时器",
  "version": "1.3.6",
  "identifier": "com.timer.tool",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "计时器",
        "width": 680,
        "height": 620,
        "minWidth": 560,
        "minHeight": 440,
        "decorations": false,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}